*.elf
*.map
*.list

# Generated make/build files
makefile
objects.list
objects.mk
sources.mk

# CubeIDE/IAR/others scratch
*.iux

# Project metadata
.cproject
.mxproject
.project

# =========
# Node/Gradle/Android (for subfolders like teaching projects)
# =========

.gradle/
build/
out/

# =========
# Arduino
# =========

# Arduino-generated temp/build folders (if present)
*.tmp

# =========
# Misc
# =========

